# WhaleX Production Environment Template
# Copy this file to .env and replace placeholder values.
# Never share real secrets in screenshots/chat.

NODE_ENV=production
APP_URL=https://your-domain.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/whalex?retryWrites=true&w=majority

# Admin
ADMIN_EMAIL=whalex2306@gmail.com
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Email / Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=whalex2306@gmail.com
SMTP_PASS=PASTE_GOOGLE_APP_PASSWORD_HERE
EMAIL_FROM="WhaleX <whalex2306@gmail.com>"

# Access durations
PAID_ACCESS_DAYS=30
TRIAL_ACCESS_DAYS=3

# Optional: Cloudinary for uploaded screenshots/PDFs
CLOUDINARY_CLOUD_NAME=PASTE_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=PASTE_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=PASTE_CLOUDINARY_API_SECRET
